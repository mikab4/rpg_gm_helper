#!/usr/bin/env bash

set -euo pipefail

if ! git diff --name-only --diff-filter=d | grep -q '^backend/.*\.py$'; then
  echo '{"continue":true}'
  exit 0
fi

if (
  cd backend
  uv run ruff check --fix .
); then
  echo '{"continue":true}'
  exit 0
fi

echo '{"decision":"block","reason":"Ruff could not fully fix backend Python changes. Run `cd backend && uv run ruff check --fix .` and resolve the remaining issues."}'
